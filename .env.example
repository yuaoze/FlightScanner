# ⚠️ python-dotenv 不会剥掉值后面的行内注释（会被当成值的一部分），
#    所以注释要么独占一行（推荐，本文件示例），要么用引号包值 KEY="value"  # comment

# ── 数据库 ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///flightscanner.db

# ── 爬虫设置 ────────────────────────────────────────────────────────────────
# 启用的爬虫，逗号分隔（qunar / ctrip）
SCRAPER_TYPE=qunar,ctrip
# false = 显示浏览器窗口（调试用），生产必须 true
SCRAPER_HEADLESS=true
# 页面等待超时（毫秒）
SCRAPER_TIMEOUT=30000
SCRAPER_RETRY_COUNT=3

# ── AI 趋势分析（可选）──────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── 通知渠道（至少配置一个）─────────────────────────────────────────────────

# Email（SMTP）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
# Gmail 需使用「应用专用密码」（在 Google 账号 → 安全 → 2FA → 应用密码）
SMTP_PASSWORD=your-app-password

# Telegram（chat_id 通过 @userinfobot 获取）
TELEGRAM_BOT_TOKEN=123456:ABC-xxx
TELEGRAM_CHAT_ID=your-chat-id

# 飞书群机器人（FEISHU_WEBHOOK_SECRET 仅在飞书安全设置开启签名校验时填写）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
FEISHU_WEBHOOK_SECRET=

# 企业微信群机器人
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
