# DeepSeek API Configuration (兼容 OpenAI API 格式)
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Database Configuration
DATABASE_URL=sqlite:///flightscanner.db

# Notification Configuration
# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Scraper Configuration
SCRAPER_TYPE=qunar  # 选择爬虫：'qunar' 或 'ctrip'
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT=30000
SCRAPER_RETRY_COUNT=3

# Qunar Cookies (可选，用于登录认证)
# 格式：JSON数组，例如：[{"name": "cookie_name", "value": "cookie_value", "domain": ".qunar.com"}]
QUNAR_COOKIES=

# Alert Configuration
ALERT_PRICE_THRESHOLD=800
